post_install() {
	systemctl enable sunshine-edid-helper.service > /dev/null 2>&1 || true
	echo "==> sunshine-edid-helper.service enabled for next boot."
	echo "==> Start it now with: sudo systemctl start sunshine-edid-helper"
	echo "==> EDID overrides don't survive a reboot (kernel debugfs, not persisted) -"
	echo "    the daemon re-adds a resolution the first time a client asks for it again."
}

post_upgrade() {
	post_install
}
