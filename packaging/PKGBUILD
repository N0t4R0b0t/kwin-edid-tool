# Maintainer: N0t4R0b0t
pkgname=sunshine-edid-helper-git
pkgver=r1.0000000
pkgrel=1
pkgdesc="Add custom resolutions to a real display's EDID on Linux/KWin - a workaround for NVIDIA's DRM-KMS driver rejecting runtime-synthesized display modes"
arch=('any')
url="https://github.com/N0t4R0b0t/sunshine-edid-helper"
license=('MIT')
depends=('python' 'libkscreen' 'libxcvt')
optdepends=(
  'openbsd-netcat: for the Sunshine connect-hook command'
  'socat: alternative to openbsd-netcat for the Sunshine connect-hook command'
)
makedepends=('git')
provides=('sunshine-edid-helper')
conflicts=('sunshine-edid-helper')
source=("$pkgname::git+https://github.com/N0t4R0b0t/sunshine-edid-helper.git")
sha256sums=('SKIP')

pkgver() {
  cd "$pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  cd "$pkgname"

  # All three Python files live together so `import edid_lib` resolves via
  # the script's own directory - a wrapper in /usr/bin execs the real file
  # in place rather than symlinking it there (Python's sys.path[0] handling
  # for symlinked entry points is inconsistent across versions/platforms).
  install -Dm755 daemon.py "$pkgdir/usr/lib/sunshine-edid-helper/daemon.py"
  install -Dm644 edid_lib.py "$pkgdir/usr/lib/sunshine-edid-helper/edid_lib.py"
  install -Dm755 edid-custom-resolutions.py "$pkgdir/usr/lib/sunshine-edid-helper/edid-custom-resolutions.py"

  install -Dm755 /dev/stdin "$pkgdir/usr/bin/sunshine-edid-custom-resolutions" <<'WRAPPER'
#!/bin/sh
exec /usr/lib/sunshine-edid-helper/edid-custom-resolutions.py "$@"
WRAPPER

  sed 's#/opt/sunshine-edid-helper#/usr/lib/sunshine-edid-helper#' sunshine-edid-helper.service > "$srcdir/sunshine-edid-helper.service.patched"
  install -Dm644 "$srcdir/sunshine-edid-helper.service.patched" "$pkgdir/usr/lib/systemd/system/sunshine-edid-helper.service"

  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
